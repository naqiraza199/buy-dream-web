play: none;\n            font-size: 1.5rem;\n            cursor: pointer;\n            color: var(--dark);\n            transition: all 0.3s ease;\n            animation: fadeIn 0.5s ease 0.3s both;\n            width: 44px;\n            height: 44px;\n            align-items: center;\n            justify-content: center;\n            border-radius: 12px;\n            background: rgba(168, 85, 247, 0.08);\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        .hamburger:hover {\n            color: var(--primary);\n            background: rgba(168, 85, 247, 0.15);\n            transform: scale(1.05);\n        }\n\n        .hamburger.active {\n            transform: rotate(90deg);\n            background: var(--primary);\n            color: white;\n        }\n         @media (max-width: 768px) {\n            nav {\n                padding: 14px 5%;\n            }\n            \n            .nav-menu {\n                display: none;\n            }\n            \n            .cta-button {\n                display: none;\n            }\n            \n            .hamburger {\n                display: flex;\n                align-items: center;\n                justify-content: center;\n                width: 44px;\n                height: 44px;\n            }\n            \n            .hero-container {\n                grid-template-columns: 1fr;\n                gap: 50px;\n                text-align: center;\n                margin-top: 100px;\n            }\n            \n            .hero-text h1 {\n                font-size: 2.6rem;\n            }\n            \n            .hero-text p {\n                font-size: 1.15rem;\n            }\n            \n            .hero-visual {\n                margin: 0 auto;\n            }\n            \n            .visual-card {\n                max-width: 340px;\n            }\n            \n            .trust-bar {\n                justify-content: