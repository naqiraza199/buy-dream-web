ezier(0.4, 0, 0.2, 1);\n        }\n\n        @keyframes slideDown {\n            from {\n                opacity: 0;\n                transform: translateY(-100%);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        nav.scrolled {\n            padding: 12px 6%;\n            background: rgba(255, 255, 255, 0.98);\n            box-shadow: 0 4px 30px rgba(168, 85, 247, 0.12);\n        }\n\n        .logo {\n            display: flex;\n            align-items: center;\n            gap: 12px;\n            text-decoration: none;\n            font-weight: 700;\n            animation: fadeInLeft 0.6s ease 0.2s both;\n        }\n\n        .logo .icon {\n            font-size: 2.6rem;\n            background: linear-gradient(135deg, #a855f7, #ec4899, #a855f7);\n            background-size: 200% 200%;\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            animation: gradientShift 3s ease infinite;\n            transition: transform 0.4s ease;\n        }\n\n        @keyframes gradientShift {\n            0%, 100% { background-position: 0% 50%; }\n            50% { background-position: 100% 50%; }\n        }\n\n        .logo:hover .icon {\n            transform: rotateY(180deg) scale(1.1);\n        }\n\n        .logo .name {\n            font-size: 1.6rem;\n            letter-spacing: -1px;\n            color: var(--dark);\n            transition: color 0.3s ease;\n        }\n\n        .logo:hover .name {\n            color: var(--primary);\n        }\n\n        .logo .tag {\n            font-size: 0.85rem;\n            font-weight: 600;\n            color: #64748b;\n            margin-top: -4px;\n            letter-spacing: 1px;\n            transition: color 0.3s ease;\n        }\n\n        .logo:hover .tag {\n            color: var(--primary);\n        }\n\n        .nav-menu {\n            display: flex;\n            gap: 32px;\n            list-style: none;\n            align-items: center;\n        }\n\n        .nav-menu li {\n            animation: fadeInUp 0.5s ease both;\n        }\n\n        .nav-menu li:nth-child(1) { animation-delay: 0.1s; }\n        .nav-menu li:nth-child(2) { animation-delay: 0.15s; }\n        .nav-menu li:nth-child(3) { animation-delay: 0.2s; }\n        .nav-menu li:nth-child(4) { animation-delay: 0.25s; }\n        .nav-menu li:nth-child(5) { animation-delay: 0.3s; }\n        .nav-menu li:nth-child(6) { animation-delay: 0.35s; }\n\n        @keyframes fadeInUp {\n            from {\n                opacity: 0;\n                transform: translateY(20px);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes fadeInLeft {\n            from {\n                opacity: 0;\n                transform: translateX(-20px);\n            }\n            to {\n                opacity: 1;\n                transform: translateX(0);\n            }\n        }\n\n        .nav-menu a {\n            text-decoration: none;\n            color: var(--dark);\n            font-weight: 500;\n            font-size: 1rem;\n            position: relative;\n            transition: all 0.3s ease;\n            padding: 8px 0;\n        }\n\n        .nav-menu a:after {\n            content: '';\n            position: absolute;\n            width: 0;\n            height: 3px;\n            bottom: 0;\n            left: 50%;\n            transform: translateX(-50%);\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            border-radius: 2px;\n            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n        }\n\n        .nav-menu a:hover:after,\n        .nav-menu a.active:after {\n            width: 100%;\n        }\n\n        .nav-menu a:hover {\n            color: var(--primary);\n        }\n\n        .dropdown {\n            position: relative;\n        }\n\n        .dropdown-trigger {\n            display: flex;\n            align-items: center;\n            gap: 6px;\n            cursor: pointer;\n        }\n\n        .dropdown-trigger i {\n            font-size: 0.75rem;\n            transition: transform 0.3s ease;\n        }\n\n        .dropdown:hover .dropdown-trigger i {\n            transform: rotate(180deg);\n        }\n\n        .dropdown-content {\n            position: absolute;\n            top: 100%;\n            left: 50%;\n            transform: translateX(-50%) translateY(10px);\n            background: white;\n            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);\n            border-radius: 16px;\n            padding: 12px 0;\n            min-width: 280px;\n            opacity: 0;\n            visibility: hidden;\n            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n            border: 1px solid rgba(168, 85, 247, 0.1);\n        }\n\n        .dropdown:hover .dropdown-content {\n            opacity: 1;\n            visibility: visible;\n            transform: translateX(-50%) translateY(8px);\n        }\n\n        .dropdown-content a {\n            padding: 14px 20px;\n            display: flex;\n            align-items: center;\n            gap: 14px;\n            color: var(--dark);\n            font-size: 0.95rem;\n            transition: all 0.3s ease;\n        }\n\n        .dropdown-content a:hover {\n            background: linear-gradient(90deg, rgba(168, 85, 247, 0.08), rgba(34, 211, 238, 0.08));\n            color: var(--primary);\n            padding-left: 28px;\n        }\n\n        .dropdown-content .icon-wrap {\n            width: 38px;\n            height: 38px;\n            border-radius: 10px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            background: linear-gradient(135deg, rgba(168, 85, 247, 0.12), rgba(34, 211, 238, 0.08));\n            color: var(--primary);\n            font-size: 