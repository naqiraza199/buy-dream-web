{"ast":null,"code":"import FooterSection from '@/components/FooterSection.vue';\nimport NavbarSection from '@/components/NavbarSection.vue';\nimport { ref } from 'vue';\nexport default {\n  __name: 'ContactUsPage',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const formData = ref({\n      name: '',\n      email: '',\n      phone: '',\n      service: '',\n      message: ''\n    });\n    const openFaq = ref(null);\n    const contactFaqs = [{\n      question: 'How quickly will you respond to my inquiry?',\n      answer: 'We typically respond to all inquiries within 24 hours during business days. For urgent projects, we prioritize immediate responses.'\n    }, {\n      question: 'What information should I include in my message?',\n      answer: 'Please include details about your project, timeline, budget range, and any specific requirements. The more information you provide, the better we can help.'\n    }, {\n      question: 'Do you offer free consultations?',\n      answer: 'Yes! We offer free initial consultations to discuss your project needs. This helps us understand your requirements and provide an accurate quote.'\n    }];\n    const handleSubmit = () => {\n      alert('Thank you for your message! We will get back to you soon.');\n      formData.value = {\n        name: '',\n        email: '',\n        phone: '',\n        service: '',\n        message: ''\n      };\n    };\n    const toggleFaq = index => {\n      openFaq.value = openFaq.value === index ? null : index;\n    };\n    const __returned__ = {\n      formData,\n      openFaq,\n      contactFaqs,\n      handleSubmit,\n      toggleFaq,\n      FooterSection,\n      NavbarSection,\n      ref\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["FooterSection","NavbarSection","ref","formData","name","email","phone","service","message","openFaq","con