     <!-- Branch Locations -->\n        <div class=\"branches-grid\">\n            \n            <!-- UK Branch -->\n            <div class=\"branch-card\">\n                <div class=\"branch-header\">\n                  <div class=\"branch-icon uk-icon\">\n                    <i class=\"fas fa-building\"></i>\n                  </div>\n                  <div class=\"branch-title\">\n                    <h3>United Kingdom</h3>\n                    <span>London Headquarters</span>\n                  </div>\n                </div>\n                \n                <div class=\"contact-info\">\n                    <div class=\"info-item\">\n                        <div class=\"info-icon\">\n                          <i class=\"fas fa-phone\"></i>\n                        </div>\n                        <div class=\"info-content\">\n                            <span class=\"info-label\">Phone</span>\n                            <a href=\"tel:+447575822382\">+44 7575822382</a>\n                        </div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-icon\">\n                          <i class=\"fas fa-envelope\"></i>\n                        </div>\n                        <div class=\"info-content\">\n                            <span class=\"info-label\">Email</span>\n                            <a href=\"mailto:support-uk@buydreamweb.com\">support-uk@buydreamweb.com</a>\n                        </div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-icon\">\n                          <i class=\"fas fa-map-marker-alt\"></i>\n                        </div>\n                        <div class=\"info-content\">\n                            <span class=\"info-label\">Address</span>\n                            <address>High Street North, East Ham, London E6 2JA, UK</address>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"map-container\">\n                  <iframe \n                    src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2483.691366220818!2d0.03258917635793526!3d51.50684797104623!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47d8a00b5c8c2e7b%3A0x40b2a125c7c8a0!2sEast%20Ham%2C%20London%20E6%202JA%2C%20UK!5e0!3m2!1sen!2s!4v1700000000000!5m2!1sen!2s\" \n                    width=\"100%\" \n                    height=\"220\" \n                    style=\"border:0;\" \n                    allowfullscreen=\"\" \n                    loading=\"lazy\" \n                    referrerpolicy=\"no-referrer-when-downgrade\">\n                  </iframe>\n                </div>\n            </div>\n\n            <!-- US Branch -->\n            <div class=\"branch-card\">\n                <div class=\"branch-header\">\n                  <div class=\"branch-icon us-icon\">\n                    <i class=\"fas fa-flag-usa\"></i>\n                  </div>\n                  <div class=\"branch-title\">\n                    <h3>United States</h3>\n                    <span>New York Office</span>\n                  </div>\n                </div>\n                \n                <div class=\"contact-info\">\n                    <div class=\"info-item\">\n                        <div class=\"info-icon\">\n                          <i class=\"fas fa-phone\"></i>\n                        </div>\n                        <div class=\"info-content\">\n                            <span class=\"info-label\">Phone</span>\n                            <a href=\"tel:+17164193200\">+1 716 419 3200</a>\n                        </div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-icon\">\n                          <i class=\"fas fa-envelope\"></i>\n                        </div>\n                        <div class=\"info-content\">\n                            <span class=\"info-label\">Email</span>\n                            <a href=\"mailto:support-us@buydreamweb.com\">support-us@buydreamweb.com</a>\n                        </div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-icon\">\n                          <i class=\"fas fa-map-marker-alt\"></i>\n                        </div>\n                        <div class=\"info-content\">\n                            <span class=\"info-label\">Address</span>\n                            <address>2089 Jarvis Street, Buffalo, NY 14202, USA</address>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"map-container\">\n                  <iframe \n                    src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2931.423456789!2c-78.87654321!3d42.90123456!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89d3123456789abc%3A0x1234567890abcdef!2s2089%20Jarvis%20St%2C%20Buffalo%2C%20NY%2014202!5e0!3m2!1sen!2s!4v1700000000000!5m2!1sen!2s\" \n                    width=\"100%\" \n                    height=\"220\" \n                    style=\"border:0;\" \n                    allowfullscreen=\"\" \n                    loading=\"lazy\" \n                    referrerpolicy=\"no-referrer-when-downgrade\">\n                  </iframe>\n                </div>\n            </div>\n        </div>\n\n        <!-- Contact Form -->\n        <div class=\"contact-form-section\">\n            <div class=\"form-header\">\n                <span class=\"section-tag\">GET IN TOUCH</span>\n                <h2>Let's Work <span>Together</span></h2>\n                <p>Ready to take your business to the next level? Contact us today for a free consultation.</p>\n            </div>\n            \n            <form class=\"contact-form\" @submit.prevent=\"handleSubmit\">\n                <div class=\"form-row\">\n                    <div class=\"form-group\">\n                        <label for=\"full_name\">Full Name</label>\n                        <input \n                          type=\"text\" \n                          id=\"full_name\" \n                          v-model=\"formData.full_name\"\n                          placeholder=\"Enter your full name\" \n                          required>\n                    </div>\n                    <div class=\"form-group\">\n                        <label for=\"email\">Email Address</label>\n                        <input \n                          type=\"email\" \n                          id=\"email\"\n                          v-model=\"formData.email\"\n                          placeholder=\"Enter your email address\" \n                          required>\n                    </div>\n                </div>\n                <div class=\"form-row\">\n                    <div class=\"form-group\">\n                        <label for=\"phone\">Phone Number</label>\n                        <input \n                          type=\"tel\" \n                          id=\"phone\"\n                          v-model=\"formData.phone\"\n                          placeholder=\"Enter your phone number\">\n                    </div>\n                    <div class=\"form-group\">\n                        <label for=\"company\">Company Name</label>\n                        <input \n                          type=\"text\" \n                          id=\"company\"\n                          v-model=\"formData.company\"\n                          placeholder=\"Company name (optional)\">\n                    </div>\n                </div>\n                <div class=\"form-group\">\n                    <label for=\"notes\">Message</label>\n                    <textarea \n                      id=\"notes\"\n                      v-model=\"formData.notes\"\n                      placeholder=\"Tell us about your project...\" \n                      rows=\"4\"></textarea>\n                </div>\n                <button type=\"submit\" class=\"submit-btn\" :disabled=\"isSubmitting\">\n                    <template v-if=\"isSubmitting\">\n                        <i class=\"fas fa-spinner fa-spin\"></i>\n                        Sending...\n                    </template>\n                    <template v-else>\n                        <i class=\"fas fa-paper-plane\"></i>\n                        Send Message\n                    </template>\n                </button>\n            </form>\n        </div>\n    </div>\n</section>\n\n    <!-- FAQ Section -->\n    <section class=\"contact-faq\">\n      <div class=\"faq-container\">\n        <div class=\"faq-header\">\n          <span class=\"section-tag\">FAQ</span>\n          <h2>Frequently Asked <span>Questions</span></h2>\n          <p>Quick answers to common questions about working with us.</p>\n        </div>\n        \n        <div class=\"faq-grid\">\n          <div class=\"faq-item\" v-for=\"(faq, index) in contactFaqs\" :key=\"index\">\n            <button class=\"faq-question\" @click=\"toggleFaq(index)\">\n              <span class=\"faq-icon\"><i class=\"fas fa-circle-question\"></i></span>\n              <span class=\"faq-text\">{{ faq.question }}</span>\n              <span class=\"faq-arrow\" :class=\"{ active: openFaq === index }\">\n                <i class=\"fas fa-chevron-down\"></i>\n              </span>\n            </button>\n            <div class=\"faq-answer\" :class=\"{ active: openFaq === index }\">\n              <p>{{ faq.answer }}</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  </div>\n  <FooterSection />\n</template>\n\n<script setup>\nimport FooterSection from '@/components/FooterSection.vue'\nimport NavbarSection from '@/components/NavbarSection.vue'\nimport { ref } from 'vue'\n\nconst formData = ref({\n  name: '',\n  email: '',\n  phone: '',\n  service: '',\n  message: ''\n})\n\nconst openFaq = ref(null)\n\nconst contactFaqs = [\n  {\n    question: 'How quickly will you respond to my inquiry?',\n    answer: 'We typically respond to all inquiries within 24 hours during business days. For urgent projects, we prioritize immediate responses.'\n  },\n  {\n    question: 'What information should I include in my message?',\n    answer: 'Please include details about your project, timeline, budget range, and any specific requirements. The more information you provide, the better we can help.'\n  },\n  {\n    question: 'Do you offer free consultations?',\n    answer: 'Yes! We offer free initial consultations to discuss your project needs. This helps us understand your requirements and provide an accurate quote.'\n  }\n]\n\nconst handleSubmit = () => {\n  alert('Thank you for your message! We will get back to you soon.')\n  formData.value = {\n    name: '',\n    email: '',\n    phone: '',\n    service: '',\n    message: ''\n  }\n}\n\nconst toggleFaq = (index) => {\n  openFaq.value = openFaq.value === index ? null : index\n}\n</script>\n\n<style scoped>\n.contact-page {\n  min-height: 100vh;\n  background: #f8fafc;\n}\n\n.contact-hero {\n  padding: 180px 6% 120px;\n  background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);\n  position: relative;\n  overflow: hidden;\n}\n\n.contact-hero-bg {\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  pointer-events: none;\n}\n\n.hero-circle {\n  position: absolute;\n  border-radius: 50%;\n  filter: blur(80px);\n}\n\n.hero-circle-1 {\n  width: 500px;\n  height: 500px;\n  top: -200px;\n  right: -100px;\n  background: radial-gradient(circle, rgba(168, 85, 247, 0.35) 0%, transparent 70%);\n  animation: float1 20s ease-in-out infinite;\n}\n\n.hero-circle-2 {\n  width: 400px;\n  height: 400px;\n  bottom: -150px;\n  left: -100px;\n  background: radial-gradient(circle, rgba(34, 211, 238, 0.3) 0%, transparent 70%);\n  animation: float2 25s ease-in-out infinite;\n}\n\n.hero-circle-3 {\n  width: 300px;\n  height: 300px;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  background: radial-gradient(circle, rgba(236, 72, 153, 0.15) 0%, transparent 70%);\n  animation: float3 30s ease-in-out infinite;\n}\n\n@keyframes float1 {\n  0%, 100% { transform: translate(0, 0); }\n  50% { transform: translate(-50px, 50px); }\n}\n\n@keyframes float2 {\n  0%, 100% { transform: translate(0, 0); }\n  50% { transform: translate(50px, -30px); }\n}\n\n@keyframes float3 {\n  0%, 100% { transform: translate(-50%, -50%); }\n  50% { transform: translate(-45%, -55%); }\n}\n\n.contact-hero-content {\n  max-width: 800px;\n  margin: 0 auto;\n  text-align: center;\n  position: relative;\n  z-index: 1;\n}\n\n.contact-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  background: linear-gradient(135deg, rgba(168, 85, 247, 0.2), rgba(236, 72, 153, 0.1));\n  color: #d8b4fe;\n  padding: 14px 32px;\n  border-radius: 50px;\n  font-size: 0.9rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 1.5px;\n  margin-bottom: 28px;\n  border: 1px solid rgba(168, 85, 247, 0.2);\n}\n\n.contact-hero-content h1 {\n  font-size: 4.5rem;\n  font-weight: 800;\n  color: white;\n  margin-bottom: 24px;\n  letter-spacing: -0.03em;\n  line-height: 1.1;\n}\n\n.contact-hero-content h1 span {\n  background: linear-gradient(135deg, #22d3ee, #a855f7, #ec4899);\n  -webkit-background-clip: text;\n  background-clip: text;\n  color: transparent;\n}\n\n.contact-hero-content > p {\n  font-size: 1.25rem;\n  color: #94a3b8;\n  max-width: 550px;\n  margin: 0 auto 40px;\n  line-height: 1.8;\n}\n\n.hero-stats {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 40px;\n  margin-top: 50px;\n}\n\n.stat-item {\n  text-align: center;\n}\n\n.stat-number {\n  display: block;\n  font-size: 2.5rem;\n  font-weight: 800;\n  color: white;\n  background: linear-gradient(135deg, #22d3ee, #a855f7);\n  -webkit-background-clip: text;\n  background-clip: text;\n  color: transparent;\n}\n\n.stat-label {\n  font-size: 0.9rem;\n  color: #64748b;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n}\n\n.stat-divider {\n  width: 1px;\n  height: 50px;\n  background: linear-gradient(to bottom, transparent, rgba(168, 85, 247, 0.3), transparent);\n}\n\n/* Branches Section */\n.contact-branches-section {\n  padding: 100px 6% 120px;\n  background: linear-gradient(180deg, #f8fafc 0%, #ffffff 50%, #fdf4ff 100%);\n}\n\n.contact-branches-container {\n  max-width: 1280px;\n  margin: 0 auto;\n}\n\n.section-header {\n  text-align: center;\n  margin-bottom: 60px;\n}\n\n.section-tag {\n  display: inline-block;\n  background: linear-gradient(135deg, rgba(168, 85, 247, 0.15), rgba(34, 211, 238, 0.1));\n  color: #a855f7;\n  padding: 10px 24px;\n  border-radius: 50px;\n  font-size: 0.8rem;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 1.5px;\n  margin-bottom: 20px;\n  border: 1px solid rgba(168, 85, 247, 0.15);\n}\n\n.section-header h2 {\n  font-size: 3rem;\n  font-weight: 800;\n  color: #0f172a;\n  margin-bottom: 16px;\n}\n\n.section-header h2 span {\n  background: linear-gradient(135deg, #a855f7, #22d3ee);\n  -webkit-background-clip: text;\n  background-clip: text;\n  color: transparent;\n}\n\n.section-header > p {\n  color: #64748b;\n  font-size: 1.1rem;\n  max-width: 500px;\n  margin: 0 auto;\n}\n\n.branches-grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 40px;\n  margin-bottom: 100px;\n}\n\n.branch-card {\n  background: white;\n  border-radius: 24px;\n  padding: 36px;\n  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);\n  border: 1px solid rgba(168, 85, 247, 0.08);\n  transition: all 0.4s ease;\n}\n\n.branch-card:hover {\n  transform: translateY(-8px);\n  box-shadow: 0 20px 50px rgba(168, 85, 247, 0.15);\n}\n\n.branch-header {\n  display: flex;\n  align-items: center;\n  gap: 20px;\n  margin-bottom: 28px;\n}\n\n.branch-icon {\n  width: 64px;\n  height: 64px;\n  border-radius: 16px;\n  di