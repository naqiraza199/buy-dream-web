data-v-393e59c1></i></div><h3 data-v-393e59c1>Fast Delivery</h3><p data-v-393e59c1>Quick turnaround times to get your project live faster.</p></div><div class=\\\"feature-item\\\" data-v-393e59c1><div class=\\\"feature-icon\\\" data-v-393e59c1><i class=\\\"fas fa-headset\\\" data-v-393e59c1></i></div><h3 data-v-393e59c1>24/7 Support</h3><p data-v-393e59c1>Round-the-clock assistance for all your needs.</p></div><div class=\\\"feature-item\\\" data-v-393e59c1><div class=\\\"feature-icon\\\" data-v-393e59c1><i class=\\\"fas fa-shield-alt\\\" data-v-393e59c1></i></div><h3 data-v-393e59c1>Secure &amp; Reliable</h3><p data-v-393e59c1>Enterprise-grade security for your peace of mind.</p></div><div class=\\\"feature-item\\\" data-v-393e59c1><div class=\\\"feature-icon\\\" data-v-393e59c1><i class=\\\"fas fa-sync\\\" data-v-393e59c1></i></div><h3 data-v-393e59c1>Free Revisions</h3><p data-v-393e59c1>Unlimited changes until you&#39;re completely satisfied.</p></div></div></div></section>\", 1)), _createCommentVNode(\" FAQ Section \"), _createElementVNode(\"section\", _hoisted_18, [_createElementVNode(\"div\", _hoisted_19, [_cache[8] || (_cache[8] = _createElementVNode(\"div\", {\n    class: \"section-header\"\n  }, [_createElementVNode(\"span\", {\n    class: \"section-tag\"\n  }, \"FAQ\"), _createElementVNode(\"h2\", null, [_createTextVNode(\"Common \"), _createElementVNode(\"span\", null, \"Questions\")])], -1 /* CACHED */)), _createElementVNode(\"div\", _hoisted_20, [(_openBlock(), _createElementBlock(_Fragment, null, _renderList($setup.faqs, (faq, index) => {\n    return _createElementVNode(\"div\", {\n      class: \"faq-item\",\n      key: index\n    }, [_createElementVNode(\"button\", {\n      class: \"faq-question\",\n      onClick: $event => $setup.toggleFaq(index)\n    }, [_cache[7] || (_cache[7] = _createElementVNode(\"span\", {\n      class: \"faq-icon\"\n    }, [_createElementVNode(\"i\", {\n      class: \"fas fa-question-circle\"\n    })], -1 /* CACHED */)), _createElementVNode(\"span\", _hoisted_22, _toDisplayString(faq.question), 1 /* TEXT */), _createElementVNode(\"span\", {\n      class: _normalizeClass([\"faq-arrow\", {\n        active: $setup.openFaq === index\n      }])\n    }, [...(_cache[6] || (_cache[6] = [_createElementVNode(\"i\", {\n      class: \"fas fa-chevron-down\"\n    }, null, -1 /* CACHED */)]))], 2 /* CLASS */)], 8 /* PROPS */, _hoisted_21), _createElementVNode(\"div\", {\n      class: _normalizeClass([\"faq-answer\", {\n        active: $setup.openFaq === index\n      }])\n    }, [_createElementVNode(\"p\", null, _toDisplayString(faq.answer), 1 /* TEXT */)], 2 /* CLASS */)]);\n  }), 64 /* STABLE_FRAGMENT */))])])])]), _createVNode($setup[\"FooterSection\"])], 64 /* STABLE_FRAGMENT */);\n}","map":{"version":3,"names":["class","href","_createVNode","$setup","_createElementVNode","_hoisted_1","_createCommentVNode","_hoisted_2","_hoisted_3","loading","_createElementBlock","_hoisted_4","_cache","error","_Fragment","key","_hoisted_5","_toDisplayString","_hoisted_6","_renderList","tabs","tab","id","_normalizeClass","active","activeTab","onClick","$event","icon","name","_hoisted_8","filteredPackages","pkg","index","popular","badge","badgeType","_hoisted_9","_hoisted_10","description","_hoisted_11","_hoisted_12","price","oldPrice","_hoisted_13","selectPlan","style","_normalizeStyle","checkout_url","background","cursor","_hoisted_15","features","feature","fIndex","target","_hoisted_17","_hoisted_18","_hoisted_19","_hoisted_20","faqs","faq","toggleFaq","_hoisted_22","question","openFaq","answer"],"sources":["/home/naqi/buy-dream-web/src/views/pages/PackagesPage.vue"],"sourcesContent":["<template>\n<NavbarSection />\n\n<div class=\"packages-page\">\n  <!-- Hero Section -->\n  <section class=\"packages-hero\">\n    <div class=\"hero-bg\">\n      <div class=\"hero-glow\"></div>\n      <div class=\"hero-glow-2\"></div>\n    </div>\n    <div class=\"hero-content\">\n      <span class=\"hero-badge\">\n        <i class=\"fas fa-tags\"></i>\n        Pricing Plans\n      </span>\n      <h1>Choose Your <span>Perfect Plan</span></h1>\n      <p style=\"color: white;\">Transparent pricing with no hidden fees. Select the package that best fits your business needs.</p>\n      <div class=\"hero-scroll\">\n        <span>Explore Plans</span>\n        <i class=\"fas fa-arrow-down\"></i>\n      </div>\n    </div>\n  </section>\n\n  <!-- Pricing Section -->\n  <section class=\"pricing-section\">\n    <div class=\"pricing-container\">\n      <!-- Loading State -->\n      <div v-if=\"loading\" class=\"loading-state\">\n        <div class=\"spinner\"></div>\n        <p>Loading packages...</p>\n      </div>\n\n      <!-- Error State -->\n      <div v-else-if=\"error\" class=\"error-state\">\n        <i class=\"fas fa-exclamation-triangle\"></i>\n        <p>{{ error }}</p>\n      </div>\n\n      <template v-else>\n        <!-- Category Tabs -->\n        <div class=\"category-tabs\">\n          <button \n            v-for=\"tab in tabs\" \n            :key=\"tab.id\"\n            class=\"tab-btn\" \n            :class=\"{ active: activeTab === tab.id }\" \n            @click=\"activeTab = tab.id\">\n            <i :class=\"tab.icon\"></i>\n            {{ tab.name }}\n          </button>\n        </div>\n\n        <!-- Pricing Grid -->\n        <div class=\"pricing-grid\">\n          <div \n            v-for=\"(pkg, index) in filteredPackages\" \n            :key=\"pkg.id || index\"\n            class=\"pricing-card\"\n            :class=\"{ popular: pkg.popular }\">\n            <div v-if=\"pkg.badge\" class=\"card-badge\" :class=\"pkg.badgeType\">\n              {{ pkg.badge }}\n            </div>\n            <div class=\"card-header\">\n              <h3>{{ pkg.name }}</h3>\n              <p class=\"card-description\">{{ pkg.description }}</p>\n            </div>\n            <div class=\"price-section\">\n              <span class=\"currency\">$</span>\n              <span class=\"amount\">{{ pkg.price }}</span>\n              <span v-if=\"pkg.oldPrice\" class=\"old-price\">${{ pkg.oldPrice }}</span>\n            </div>\n            <button \n              class=\"select-btn\" \n              @click=\"selectPlan(pkg)\"\n              :style=\"pkg.checkout_url && pkg.checkout_url !== '#' ? { background: 'linear-gradient(135deg, #22d3ee, #14b8a6)', cursor: 'pointer' } : {}\">\n              <i :class=\"pkg.checkout_url && pkg.checkout_url !== '#' ? 'fas fa-shopping-cart' : 'fas fa-rocket'\"></i>\n              {{ pkg.checkout_url && pkg.checkout_url !== '#' ? 'Buy Now' : 'Get Started' }}\n            </button>\n            <ul class=\"features-list\">\n              <li v-for=\"(feature, fIndex) in pkg.features\" :key=\"fIndex\">\n                <i class=\"fas fa-check-circle\"></i>\n                {{ feature }}\n              </li>\n            </ul>\n            <a \n              v-if=\"pkg.checkout_url && pkg.checkout_url !== '#'\"\n              :href=\"pkg.checkout_url\" \n              target=\"_blank\"\n              class=\"view-details\">\n              Checkout <i class=\"fas fa-external-link-alt\"></i>\n            </a>\n            <a v-else href=\"#\" class=\"view-details\">\n              View Details <i class=\"fas fa-arrow-right\"></i>\n            </a>\n          </div>\n        </div>\n      </template>\n    </div>\n  </section>\n\n  <!-- Features Section -->\n  <section class=\"features-section\">\n    <div class=\"features-container\">\n      <div class=\"section-header\">\n        <span class=\"section-tag\">Why Choose Us</span>\n        <h2>What's <span>Included</span></h2>\n      </div>\n      <div class=\"features-grid\">\n        <div class=\"feature-item\">\n          <div class=\"feature-icon\">\n            <i class=\"fas fa-clock\"></i>\n          </div>\n          <h3>Fast Delivery</h3>\n          <p>Quick turnaround times to get your project live faster.</p>\n        </div>\n        <div class=\"feature-item\">\n          <div class=\"feature-icon\">\n            <i class=\"fas fa-headset\"></i>\n          </div>\n          <h3>24/7 Support</h3>\n          <p>Round-the-clock assistance for all your needs.</p>\n        </div>\n        <div class=\"feature-item\">\n          <div class=\"feature-icon\">\n            <i class=\"fas fa-shield-alt\"></i>\n          </div>\n          <h3>Secure & Reliable</h3>\n          <p>Enterprise-grade security for your peace of mind.</p>\n        </div>\n        <div class=\"feature-item\">\n          <div class=\"feature-icon\">\n            <i class=\"fas fa-sync\"></i>\n          </div>\n          <h3>Free Revisions</h3>\n          <p>Unlimited changes until you're completely satisfied.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- FAQ Section -->\n  <section class=\"faq-section\">\n    <div class=\"faq-container\">\n      <div class=\"section-header\">\n        <span class=\"section-tag\">FAQ</span>\n        <h2>Common <span>Questions</span></h2>\n      </div>\n      <div class=\"faq-grid\">\n        <div class=\"faq-item\" v-for=\"(faq, index) in faqs\" :key=\"index\">\n          <button class=\"faq-question\" @click=\"toggleFaq(index)\">\n            <span class=\"faq-icon\"><i class=\"fas fa-question-circle\"></i></span>\n            <span class=\"faq-text\">{{ faq.question }}</span>\n            <span class=\"faq-arrow\" :class=\"{ active: openFaq === index }\">\n              <i class=\"fas fa-chevron-down\"></i>\n            </span>\n          </button>\n          <div class=\"faq-answer\" :class=\"{ active: openFaq === index }\">\n            <p>{{ faq.answer }}</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>\n\n<FooterSection />\n</template>\n\n<script setup>\nimport { ref, computed, onMounted } from 'vue'\nimport FooterSection from '@/components/FooterSection.vue'\nimport NavbarSection from '@/components/NavbarSection.vue'\n\nconst activeTab = ref('all')\nconst openFaq = ref(null)\nconst packages = ref([])\nconst tabs = ref([])\nconst loading = ref(true)\nconst error = ref(null)\n\nonMounted(async () => {\n  try {\n    const response = await fetch('https://jaexlfmjjzpahdmlvhii.supabase.co/functions/v1/get-services')\n    const data = await response.json()\n    \n    if (data.success && data.services) {\n      packages.value = data.services.map(pkg => ({\n        id: pkg.id,\n        name: pkg.name,\n        description: pkg.description,\n        price: pkg.sale_price || pkg.price,\n        regular_price: pkg.regular_price,\n        oldPrice: pkg.regular_price && pkg.regular_price > (pkg.sale_price || pkg.price) ? pkg.regular_price : null,\n        popular: pkg.is_popular || false,\n        recommended: pkg.is_recommended || false,\n        badge: pkg.is_popular ? 'Most Popular' : (pkg.is_recommended ? 'Recommended' : null),\n        badgeType: pkg.is_popular ? 'popular' : (pkg.is_recommended ? 'recommended' : ''),\n        features: pkg.features || [],\n        category: pkg.category || 'General',\n        checkout_url: pkg.checkout_url || '#'\n      }))\n\n      const categories = [...new Set(packages.value.map(p => p.category))]\n      tabs.value = [\n        { id: 'all', name: 'All', icon: 'fas fa-th-large' },\n        ...categories.map(cat => ({\n          id: cat.toLowerCase().replace(/\\s+/g, '-'),\n          name: cat,\n          icon: getCategoryIcon(cat)\n        }))\n      ]\n    }\n  } catch (err) {\n    error.value = err.message\n    console.error('Failed to fetch packages:', err)\n  } finally {\n    loading.value = false\n  }\n})\n\nconst getCategoryIcon = (category) => {\n  const icons = {\n    'Overview': 'fas fa-th-large',\n    'Ecommerce': 'fas fa-shopping-cart',\n    'Website': 'fas fa-globe',\n    'Logo': 'fas fa-pen-nib',\n    'App': 'fas fa-mobile-alt',\n    'Marketing': 'fas fa-bullhorn'\n  }\n  return icons[category] || 'fas fa-layer-group'\n}\n\nconst filteredPackages = computed(() => {\n  if (activeTab.value === 'all') return packages.value\n  return packages.value.filter(pkg => \n    pkg.category.toLowerCase().replace(/\\s+/g, '-') === activeTab.value\n  )\n})\n\nconst selectPlan = (pkg) => {\n  if (pkg.checkout_url && pkg.checkout_url !== '#') {\n    window.open(pkg.checkout_url, '_blank')\n  } else {\n    alert(`You selected the ${pkg.name} plan! Our team will contact you shortly.`)\n  }\n}\n\nconst toggleFaq = (index) => {\n  openFaq.value = openFaq.value === index ? null : index\n}\n\nconst faqs = [\n  {\n    question: 'Do you offer custom pricing for specific projects?',\n    answer: 'Yes, we offer custom pricing based on your specific requirements. Contact us for a personalized quote.'\n  },\n  {\n    question: 'What payment methods do you accept?',\n    answer: 'We accept all major credit cards, PayPal, bank transfers, and offer flexible payment plans for larger projects.'\n  },\n  {\n    question: 'Is there a refund policy?',\n    answer: 'Yes, we offer a 100% refund within the first 7 days if you are not satisfied with our services.'\n  },\n  {\n    question: 'Do you provide ongoing maintenance?',\n    answer: 'Absolutely! We offer various maintenance packages to keep your website or app running smoothly.'\n  }\n]\n</script>\n\n<style scoped>\n.packages-page {\n  min-height: 100vh;\n  background: #f8fafc;\n}\n\n/* Hero Section */\n.packages-hero {\n  padding: 200px 6% 140px;\n  background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);\n  position: relative;\n  overflow: hidden;\n}\n\n.hero-bg {\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  pointer-events: none;\n}\n\n.hero-glow {\n  position: absolute;\n  width: 500px;\n  height: 500px;\n  top: -200px;\n  right: -100px;\n  background: radial-gradient(circle, rgba(168, 85, 247, 0.35) 0%, transparent 70%);\n  filter: blur(80px);\n}\n\n.hero-glow-2 {\n  position: absolute;\n  width: 400px;\n  height: 400px;\n  bottom: -150px;\n  left: -100px;\n  background: radial-gradient(