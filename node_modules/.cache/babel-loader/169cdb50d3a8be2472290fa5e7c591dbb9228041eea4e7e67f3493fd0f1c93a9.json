  </div>\n                <div class=\"form-group\">\n                    <label for=\"phone\">Phone Number</label>\n                    <input \n                      type=\"tel\" \n                      id=\"phone\"\n                      v-model=\"formData.phone\"\n                      placeholder=\"Enter your phone number\" \n                      required>\n                </div>\n                <button type=\"submit\" class=\"submit-btn\">\n                    <i class=\"fas fa-paper-plane\"></i>\n                    Send Message\n                </button>\n            </form>\n        </div>\n    </div>\n</section>\n\n    <!-- FAQ Section -->\n    <section class=\"contact-faq\">\n      <div class=\"faq-container\">\n        <div class=\"faq-header\">\n          <span class=\"section-tag\">FAQ</span>\n          <h2>Frequently Asked <span>Questions</span></h2>\n          <p>Quick answers to common questions about working with us.</p>\n        </div>\n        \n        <div class=\"faq-grid\">\n          <div class=\"faq-item\" v-for=\"(faq, index) in contactFaqs\" :key=\"index\">\n            <button class=\"faq-question\" @click=\"toggleFaq(index)\">\n              <span class=\"faq-icon\"><i class=\"fas fa-circle-question\"></i></span>\n              <span class=\"faq-text\">{{ faq.question }}</span>\n              <span class=\"faq-arrow\" :class=\"{ active: openFaq === index }\">\n                <i class=\"fas fa-chevron-down\"></i>\n              </span>\n            </button>\n            <div class=\"faq-answer\" :class=\"{ active: openFaq === index }\">\n              <p>{{ faq.answer }}</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  </div>\n  <FooterSection />\n</template>\n\n<script setup>\nimport FooterSection from '@/components/FooterSection.vue'\nimport NavbarSection from '@/components/NavbarSection.vue'\nimport { ref } from 'vue'\n\nconst formData = ref({\n  name: '',\n  email: '',\n  phone: '',\n  se