together.</p>\n        <div class=\"hero-stats\">\n          <div class=\"stat-item\">\n            <span class=\"stat-number\">500+</span>\n            <span class=\"stat-label\">Projects Completed</span>\n          </div>\n          <div class=\"stat-divider\"></div>\n          <div class=\"stat-item\">\n            <span class=\"stat-number\">98%</span>\n            <span class=\"stat-label\">Client Satisfaction</span>\n          </div>\n          <div class=\"stat-divider\"></div>\n          <div class=\"stat-item\">\n            <span class=\"stat-number\">24/7</span>\n            <span class=\"stat-label\">Support Available</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n   <!-- ==================== CONTACT & BRANCHES SECTION ==================== -->\n<section class=\"contact-branches-section\">\n    <div class=\"contact-branches-container\">\n        <div class=\"section-header\">\n          <span class=\"section-tag\">OUR LOCATIONS</span>\n          <h2>Visit Our <span>Global Offices</span></h2>\n          <p>We have strategic locations in key financial hubs to serve you better.</p>\n        </div>\n        \n        <!-- Branch Locations -->\n        <div class=\"branches-grid\">\n            \n            <!-- UK Branch -->\n            <div class=\"branch-card\">\n                <div class=\"branch-header\">\n                  <div class=\"branch-icon uk-icon\">\n                    <i class=\"fas fa-building\"></i>\n                  </div>\n                  <div class=\"branch-title\">\n                    <h3>United Kingdom</h3>\n                    <span>London Headquarters</span>\n                  </div>\n                </div>\n                \n                <div class=\"contact-info\">\n                    <div class=\"info-item\">\n                        <div class=\"info-icon\">\n                          <i class=\"fas fa-phone\"></i>\n                        </div>\n                        <div class=\"info-content\">\n                            <span class=\"info-label\">Phone</span>\n                            <a href=\"tel:+447575822382\">+44 7575822382</a>\n                        </div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-icon\">\n                          <i class=\"fas fa-envelope\"></i>\n                        </div>\n                        <div class=\"info-content\">\n                            <span class=\"info-label\">Email</span>\n                            <a href=\"mailto:support-uk@buydreamweb.com\">support-uk@buydreamweb.com</a>\n                        </div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-icon\">\n                          <i class=\"fas fa-map-marker-alt\"></i>\n                        </div>\n                        <div class=\"info-content\">\n                            <span class=\"info-label\">Address</span>\n                            <address>High Street North, East Ham, London E6 2JA, UK</address>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"map-container\">\n                  <iframe \n                    src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2483.691366220818!2d0.03258917635793526!3d51.50684797104623!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47d8a00b5c8c2e7b%3A0x40b2a125c7c8a0!2sEast%20Ham%2C%20London%20E6%202JA%2C%20UK!5e0!3m2!1sen!2s!4v1700000000000!5m2!1sen!2s\" \n                    width=\"100%\" \n                    height=\"220\" \n                    style=\"border:0;\" \n                    allowfullscreen=\"\" \n                    loading=\"lazy\" \n                    referrerpolicy=\"no-referrer-when-downgrade\">\n                  </iframe>\n                </div>\n            </div>\n\n            <!-- US Branch -->\n            <div class=\"branch-card\">\n                <div class=\"branch-header\">\n                  <div class=\"branch-icon us-icon\">\n                    <i class=\"fas fa-flag-usa\"></i>\n                  </div>\n                  <div class=\"branch-title\">\n                    <h3>United States</h3>\n                    <span>New York Office</span>\n                  </div>\n                </div>\n                \n                <div class=\"contact-info\">\n                    <div class=\"info-item\">\n                        <div class=\"info-icon\">\n                          <i class=\"fas fa-phone\"></i>\n                        </div>\n                        <div class=\"info-content\">\n                            <span class=\"info-label\">Phone</span>\n                            <a href=\"tel:+17164193200\">+1 716 419 3200</a>\n                        </div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-icon\">\n                          <i class=\"fas fa-envelope\"></i>\n                        </div>\n                        <div class=\"info-content\">\n                            <span class=\"info-label\">Email</span>\n                            <a href=\"mailto:support-us@buydreamweb.com\">support-us@buydreamweb.com</a>\n                        </div>\n                    </div>\n                    <div class=\"info-item\">\n                        <div class=\"info-icon\">\n                          <i class=\"fas fa-map-marker-alt\"></i>\n                        </div>\n                        <div class=\"info-content\">\n                            <span class=\"info-label\">Address</span>\n                            <address>2089 Jarvis Street, Buffalo, NY 14202, USA</address>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"map-container\">\n                  <iframe \n                   