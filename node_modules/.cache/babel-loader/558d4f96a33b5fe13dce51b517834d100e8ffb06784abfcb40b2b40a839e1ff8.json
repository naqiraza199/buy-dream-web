{"ast":null,"code":"import { ref } from 'vue';\nexport default {\n  __name: 'FooterSection',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const newsletterEmail = ref('');\n    const subscribeNewsletter = () => {\n      alert(\"🎉 Successfully subscribed! Welcome to our community.\");\n      newsletterEmail.value = '';\n    };\n    const __returned__ = {\n      newsletterEmail,\n      subscribeNewsletter,\n      ref\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","newsletterEmail","subscribeNewsletter","alert","value"],"sources":["/home/naqi/buy-dream-web/src/components/FooterSection.vue"],"sourcesContent":["<template>\n      <!-- FOOTER -->\n  <footer class=\"footer\">\n    <div class=\"footer-glow\"></div>\n    <div class=\"footer-glow-2\"></div>\n    \n    <div class=\"footer-main\">\n      <div class=\"footer-brand\">\n        <router-link to=\"/\" class=\"footer-logo\">\n          <img width=\"200\" src=\"/images/bdy2.webp\" alt=\"Buy Dream Web\">\n        </router-link>\n        <p>We are a full-service web development agency helping startups, SMEs, and enterprises thrive online...</p>\n        <div class=\"footer-social\">\n          <a href=\"#\" aria-label=\"Facebook\"><i class=\"fab fa-facebook-f\"></i></a>\n          <a href=\"#\" aria-label=\"Twitter\"><i class=\"fab fa-twitter\"></i></a>\n          <a href=\"#\" aria-label=\"Instagram\"><i class=\"fab fa-instagram\"></i></a>\n          <a href=\"#\" aria-label=\"LinkedIn\"><i class=\"fab fa-linkedin-in\"></i></a>\n          <a href=\"#\" aria-label=\"Dribbble\"><i class=\"fab fa-dribbble\"></i></a>\n        </div>\n      </div>\n      \n      <!-- Quick Links, Services, Contact columns remain same -->\n      <!-- (I kept them identical to original for fidelity) -->\n      <div class=\"footer-column\">\n        <h4>Quick Links</h4>\n        <ul class=\"footer-links\">\n          <li><router-link to=\"/\" class=\"footer-link\">Home</router-link></li>\n          <li><router-link to=\"/about\" class=\"footer-link\">About Us</router-link></li>\n          <li><router-link to=\"/packages\" class=\"footer-link\">Packages</router-link></li>\n          <li><router-link to=\"/faq\" class=\"footer-link\">FAQ</router-link></li>\n          <li><router-link to=\"/contact\" class=\"footer-link\">Contact Us</router-link></li>\n        </ul>\n      </div>\n      \n      <div class=\"footer-column\"> \n        <h4>Our Services</h4>\n        <ul class=\"footer-links\">\n          <li><router-link to=\"/website-design\" class=\"footer-link\">Website Design</router-link></li>\n          <li><router-link to=\"/logo-design\" class=\"footer-link\">Logo Design</router-link></li>\n          <li><router-link to=\"/brand-identity\" class=\"footer-link\">Brand Identity</router-link></li>\n          <li><router-link to=\"/app-development\" class=\"footer-link\">App Development</router-link></li>\n          <li><router-link to=\"/seo\" class=\"footer-link\">SEO Services</router-link></li>\n          <li><router-link to=\"/digital-marketing\" class=\"footer-link\">Digital Marketing</router-link></li>\n        </ul>\n      </div>\n      \n      <div class=\"footer-column\">\n        <h4>Get In Touch</h4>\n        <div class=\"footer-contact-item\">\n          <i class=\"fas fa-map-marker-alt\"></i>\n          <span>123 Digital Avenue, Tech Park<br>London, UK EC1A 1BB</span>\n        </div>\n        <div class=\"footer-contact-item\">\n          <i class=\"fas fa-phone-alt\"></i>\n          <span><a href=\"tel:+44757822382\">+44 7578 22382</a></span>\n        </div>\n        <div class=\"footer-contact-item\">\n          <i class=\"fas fa-envelope\"></i>\n          <span><a href=\"mailto:hello@bdw.com\">hello@bdw.com</a></span>\n        </div>\n        \n        <div class=\"footer-newsletter\">\n          <p>Subscribe to our newsletter for updates and insights.</p>\n          <form class=\"newsletter-form\" @submit.prevent=\"subscribeNewsletter\">\n            <input type=\"email\" placeholder=\"Enter your email\" v-model=\"newsletterEmail\" required>\n            <button type=\"submit\"><i class=\"fas fa-paper-plane\"></i> Subscribe</button>\n          </form>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"footer-bottom\">\n      <div class=\"footer-bottom-content\">\n        <p class=\"footer-copyright\">© 2024 <span>Buy Dream Web</span>. All rights reserved. Crafted with ❤️</p>\n        <div class=\"footer-bottom-links\">\n          <a href=\"#\">Privacy Policy</a>\n          <a href=\"#\">Terms of Service</a>\n          <a href=\"#\">Cookie Policy</a>\n        </div>\n      </div>\n    </div>\n  </footer>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\n\nconst newsletterEmail = ref('')\n\nconst subscribeNewsletter = () => {\n  alert(\"🎉 Successfully subscribed! Welcome to our community.\")\n  newsletterEmail.value = ''\n}\n\n</script>\n\n<style scoped>\n/* ==================== ADVANCED FOOTER ==================== */\n.footer {\n    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);\n    position: relative;\n    overflow: hidden;\n}\n\n.footer::before {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 1px;\n    background: linear-gradient(90deg, transparent, var(--primary), var(--accent), transparent);\n}\n\n.footer-glow {\n    position: absolute;\n    width: 500px;\n    height: 500px;\n    background: radial-gradient(circle, rgba(168, 85, 247, 0.15) 0%, transparent 70%);\n    border-radius: 50%;\n    top: -250px;\n    right: -100px;\n    pointer-events: none;\n}\n\n.footer-glow-2 {\n    position: absolute;\n    width: 400px;\n    height: 400px;\n    background: radial-gradient(circle, rgba(34, 211, 238, 0.1) 0%, transparent 70%);\n    border-radius: 50%;\n    bottom: -200px;\n    left: -100px;\n    pointer-events: none;\n}\n\n.footer-main {\n    max-width: 1380px;\n    margin: 0 auto;\n    padding: 80px 6% 60px;\n    display: grid;\n    grid-template-columns: 1.4fr 1fr 1.2fr 1fr;\n    gap: 40px;\n    position: relative;\n    z-index: 1;\n}\n\n.footer-brand {\n    max-width: 320px;\n}\n\n.footer-logo {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    text-decoration: none;\n    margin-bottom: 24px;\n}\n\n.footer-logo .icon {\n    font-size: 2.4rem;\n    background: linear-gradient(135deg, #a855f7, #ec4899, #a855f7);\n    background-size: 200% 200%;\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    animation: gradientShift 3s ease infinite;\n}\n\n.footer-logo .name {\n    font-size: 1.5rem;\n    font-weight: 700;\n    color: white;\n    letter-spacing: -0.5px;\n}\n\n.footer-brand p {\n    color: #94a3b8;\n    line-height: 1.8;\n    font-size: 0.95rem;\n    margin-bottom: 28px;\n}\n\n.footer-social {\n    display: flex;\n    gap: 14px;\n}\n\n.footer-social a {\n    width: 44px;\n    height: 44px;\n    border-radius: 12px;\n    background: rgba(255, 255, 255, 0.05);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: #94a3b8;\n    font-size: 1.1rem;\n    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.footer-social a:hover {\n    background: linear-gradient(135deg, var(--primary), var(--accent));\n    border-color: transparent;\n    color: white;\n    transform: translateY(-5px);\n    box-shadow: 0 10px 25px rgba(168, 85, 247, 0.4);\n}\n\n.footer-column h4 {\n    color: white;\n    font-size: 1.15rem;\n    font-weight: 600;\n    margin-bottom: 24px;\n    position: relative;\n    padding-bottom: 12px;\n}\n\n.footer-column h4::after {\n    content: '';\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    width: 40px;\n    height: 3px;\n    background: linear-gradient(90deg, var(--primary), var(--accent));\n    border-radius: 2px;\n}\n\n.footer-links {\n    list-style: none;\n}\n\n.footer-links li {\n    margin-bottom: 14px;\n}\n\n.footer-links a {\n    color: #94a3b8;\n    text-decoration: none;\n    font-size: 0.95rem;\n    transition: all 0.3s ease;\n    position: relative;\n    display: inline-block;\n}\n\n.footer-links a::before {\n    content: '›';\n    color: var(--primary);\n    opacity: 0;\n    transform: translateX(-10px);\n    transition: all 0.3s ease;\n    margin-right: 4px;\n}\n\n.footer-links a:hover {\n    color: white;\n    padding-left: 12px;\n}\n\n.footer-links a:hover::before {\n    opacity: 1;\n    transform: translateX(0);\n}\n\n.footer-contact-item {\n    display: flex;\n    align-items: flex-start;\n    gap: 14px;\n    margin-bottom: 20px;\n}\n\n.footer-contact-item i {\n    width: 40px;\n    height: 40px;\n    border-radius: 10px;\n    background: linear-gradient(135deg, rgba(168, 85, 247, 0.2), rgba(34, 211, 238, 0.2));\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: var(--accent);\n    font-size: 1rem;\n    flex-shrink: 0;\n}\n\n.footer-contact-item span {\n    color: #94a3b8;\n    font-size: 0.95rem;\n    line-height: 1.6;\n}\n\n.footer-contact-item a {\n    color: #94a3b8;\n    text-decoration: none;\n    transition: color 0.3s ease;\n}\n\n.footer-contact-item a:hover {\n    color: var(--accent);\n}\n\n.footer-newsletter {\n    margin-top: 30px;\n}\n\n.footer-newsletter p {\n    color: #94a3b8;\n    font-size: 0.95rem;\n    margin-bottom: 16px;\n}\n\n.newsletter-form {\n    display: flex;\n    gap: 10px;\n}\n\n.newsletter-form input {\n    flex: 1;\n    padding: 14px 18px;\n    border-radius: 12px;\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    background: rgba(255, 255, 255, 0.05);\n    color: white;\n    font-size: 0.95rem;\n    font-family: 'Poppins', sans-serif;\n    transition: all 0.3s ease;\n}\n\n.newsletter-form input::placeholder {\n    color: #64748b;\n}\n\n.newsletter-form input:focus {\n    outline: none;\n    border-color: var(--primary);\n    background: rgba(255, 255, 255, 0.08);\n    box-shadow: 0 0 20px rgba(168, 85, 247, 0.2);\n}\n\n.newsletter-form button {\n    padding: 14px 24px;\n    border-radius: 12px;\n    border: none;\n    background: linear-gradient(135deg, var(--primary), #ec4899);\n    color: white;\n    font-weight: 600;\n    font-size: 0.95rem;\n    cursor: pointer;\n    transition: all 0.4s ease;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n}\n\n.newsletter-form button:hover {\n    transform: translateY(-3px);\n    box-shadow: 0 10px 25px rgba(168, 85, 247, 0.4);\n}\n\n.footer-bottom {\n    border-top: 1px solid rgba(255, 255, 255, 0.08);\n    padding: 24px 6%;\n    position: relative;\n    z-index: 1;\n}\n\n.footer-bottom-content {\n    max-width: 1380px;\n    margin: 0 auto;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    flex-wrap: wrap;\n    gap: 16px;\n}\n\n.footer-copyright {\n    color: #64748b;\n    font-size: 0.9rem;\n}\n\n.footer-copyright span {\n    color: var(--accent);\n    font-weight: 600;\n}\n\n.footer-bottom-links {\n    display: flex;\n    gap: 28px;\n}\n\n.footer-bottom-links a {\n    color: #64748b;\n    text-decoration: none;\n    font-size: 0.9rem;\n    transition: color 0.3s ease;\n}\n\n.footer-bottom-links a:hover {\n    color: var(--accent);\n}\n\n/* Footer Responsive */\n@media (max-width: 1200px) {\n    .footer-main {\n        grid-template-columns: 1.2fr 1fr 1fr;\n        gap: 30px;\n        padding: 70px 5% 50px;\n    }\n    \n    .footer-brand {\n        grid-column: span 3;\n        max-width: 100%;\n        text-align: center;\n    }\n    \n    .footer-logo {\n        justify-content: center;\n    }\n    \n    .footer-social {\n        justify-content: center;\n    }\n    \n    .footer-column {\n        text-align: center;\n    }\n    \n    .footer-column h4::after {\n        left: 50%;\n        transform: translateX(-50%);\n    }\n}\n\n@media (max-width: 992px) {\n    .footer-main {\n        grid-template-columns: 1fr 1fr;\n        gap: 40px;\n        padding: 60px 5% 50px;\n    }\n    \n    .footer-brand {\n        grid-column: span 2;\n    }\n    \n    .footer-column:nth-child(3) {\n        order: 4;\n    }\n    \n    .footer-column:nth-child(4) {\n        order: 3;\n    }\n    \n    .footer-contact-item {\n        justify-content: center;\n    }\n}\n\n@media (max-width: 768px) {\n    .footer-main {\n        grid-template-columns: 1fr;\n        gap: 35px;\n        padding: 50px 5% 40px;\n    }\n    \n    .footer-brand {\n        grid-column: 1;\n    }\n    \n    .footer-brand p {\n        font-size: 0.95rem;\n        line-height: 1.7;\n    }\n    \n    .footer-column h4 {\n        font-size: 1.1rem;\n        margin-bottom: 20px;\n        padding-bottom: 10px;\n    }\n    \n    .footer-column h4::after {\n        left: 50%;\n        transform: translateX(-50%);\n    }\n    \n    .footer-links {\n        padding: 0;\n        margin: 0;\n    }\n    \n    .footer-links li {\n        margin-bottom: 12px;\n    }\n    \n    .footer-links a {\n        font-size: 0.95rem;\n        padding: 8px 0;\n    }\n    \n    .footer-contact-item {\n        flex-direction: column;\n        align-items: center;\n        text-align: center;\n        gap: 12px;\n    }\n    \n    .footer-contact-item i {\n        margin: 0 auto;\n    }\n    \n    .footer-contact-item span {\n        font-size: 0.9rem;\n    }\n    \n    .footer-newsletter {\n        margin-top: 20px;\n    }\n    \n    .footer-newsletter p {\n        font-size: 0.9rem;\n    }\n    \n    .newsletter-form {\n        flex-direction: column;\n        gap: 12px;\n    }\n    \n    .newsletter-form input {\n        width: 100%;\n        text-align: center;\n    }\n    \n    .newsletter-form button {\n        width: 100%;\n        justify-content: center;\n    }\n    \n    .footer-bottom {\n        padding: 20px 5%;\n    }\n    \n    .footer-bottom-content {\n        flex-direction: column;\n        gap: 16px;\n        text-align: center;\n    }\n    \n    .footer-copyright {\n        font-size: 0.85rem;\n    }\n    \n    .footer-bottom-links {\n        flex-wrap: wrap;\n        justify-content: center;\n        gap: 16px;\n    }\n    \n    .footer-bottom-links a {\n        font-size: 0.85rem;\n    }\n}\n\n@media (max-width: 480px) {\n    .footer-main {\n        padding: 40px 4% 30px;\n        gap: 30px;\n    }\n    \n    .footer-brand {\n        max-width: 100%;\n    }\n    \n    .footer-brand p {\n        font-size: 0.85rem;\n    }\n    \n    .footer-logo img {\n        width: 160px !important;\n    }\n    \n    .footer-social {\n        gap: 10px;\n    }\n    \n    .footer-social a {\n        width: 40px;\n        height: 40px;\n        font-size: 0.95rem;\n    }\n    \n    .footer-column h4 {\n        font-size: 1rem;\n    }\n    \n    .footer-links a {\n        font-size: 0.9rem;\n    }\n    \n    .footer-contact-item i {\n        width: 36px;\n        height: 36px;\n        font-size: 0.9rem;\n    }\n    \n    .footer-newsletter p {\n        font-size: 0.85rem;\n    }\n    \n    .newsletter-form input,\n    .newsletter-form button {\n        padding: 12px 14px;\n        font-size: 0.85rem;\n    }\n}\n</style>"],"mappings":"AAqFA,SAASA,GAAG,QAAQ,KAAI;;;;;;;IAExB,MAAMC,eAAe,GAAGD,GAAG,CAAC,EAAE;IAE9B,MAAME,mBAAmB,GAAGA,CAAA,KAAM;MAChCC,KAAK,CAAC,uDAAuD;MAC7DF,eAAe,CAACG,KAAK,GAAG,EAAC;IAC3B","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}