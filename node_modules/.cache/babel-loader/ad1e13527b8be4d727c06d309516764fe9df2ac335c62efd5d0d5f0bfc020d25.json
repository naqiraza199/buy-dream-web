{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport { onMounted } from 'vue';\nimport FooterSection from '@/components/FooterSection.vue';\nimport NavbarSection from '@/components/NavbarSection.vue';\nexport default {\n  __name: 'AboutUsPage',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    onMounted(() => {\n      const cards = document.querySelectorAll('.team-card');\n      const observer = new IntersectionObserver(entries => {\n        entries.forEach((entry, index) => {\n          if (entry.isIntersecting) {\n            setTimeout(() => {\n              entry.target.style.opacity = '1';\n              entry.target.style.transform = 'translateY(0)';\n            }, index * 100);\n          }\n        });\n      }, {\n        threshold: 0.1\n      });\n      cards.forEach(card => {\n        card.style.opacity = '0';\n        card.style.transform = 'translateY(30px)';\n        card.style.transition = 'all 0.6s ease';\n        observer.observe(card);\n      });\n    });\n    const __returned__ = {\n      onMounted,\n      FooterSection,\n      NavbarSection\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["onMounted","FooterSection","NavbarSection","cards","document","querySelectorAll","observer","IntersectionObserver","entries","forEach","entry","index","isIntersecting","setTimeout","target","style","opacity","transform","threshold","card","transition","observe"],"sources":["/home/naqi/buy-dream-web/src/views/pages/AboutUsPage.vue"],"sourcesContent":["<template>\n<NavbarSection />\n\n<div class=\"about-page\">\n  <!-- Hero Section -->\n  <section class=\"about-hero\">\n    <div class=\"about-hero-bg\">\n      <div class=\"hero-particles\">\n        <span></span>\n        <span></span>\n        <span></span>\n        <span></span>\n        <span></span>\n      </div>\n    </div>\n    <div class=\"about-hero-content\">\n      <span class=\"about-badge\">\n        <i class=\"fas fa-star\"></i>\n        About Us\n      </span>\n      <h1>We Build <span>Digital Excellence</span></h1>\n      <p style=\"color: white;\">Transforming businesses through innovative web solutions and strategic digital marketing since 2010.</p>\n      <div class=\"hero-stats\">\n        <div class=\"stat-item\">\n          <span class=\"stat-number\">15+</span>\n          <span class=\"stat-label\">Years Experience</span>\n        </div>\n        <div class=\"stat-divider\"></div>\n        <div class=\"stat-item\">\n          <span class=\"stat-number\">500+</span>\n          <span class=\"stat-label\">Projects Completed</span>\n        </div>\n        <div class=\"stat-divider\"></div>\n        <div class=\"stat-item\">\n          <span class=\"stat-number\">98%</span>\n          <span class=\"stat-label\">Client Satisfaction</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- About Main Section -->\n  <section class=\"about-main\">\n    <div class=\"about-container\">\n      <div class=\"about-grid\">\n        <div class=\"about-content\">\n          <span class=\"section-tag\">Who We Are</span>\n          <h2>Elevate Your Business With <span>Cutting-Edge</span> Digital Strategies</h2>\n          <p>At Buy Dream Web, we deliver exceptional digital marketing services and e-commerce solutions designed to propel your enterprise forward in a competitive landscape.</p>\n          <p>Our team of experts specializes in creating stunning websites, implementing effective SEO strategies, and driving measurable business growth through data-driven marketing approaches.</p>\n          \n          <div class=\"feature-list\">\n            <div class=\"feature-item\">\n              <div class=\"feature-icon\">\n                <i class=\"fas fa-check\"></i>\n              </div>\n              <div>\n                <h4>Custom Website Design</h4>\n                <p>Tailored designs that reflect your brand identity</p>\n              </div>\n            </div>\n            <div class=\"feature-item\">\n              <div class=\"feature-icon\">\n                <i class=\"fas fa-check\"></i>\n              </div>\n              <div>\n                <h4>SEO Optimization</h4>\n                <p>Boost your visibility and organic traffic</p>\n              </div>\n            </div>\n            <div class=\"feature-item\">\n              <div class=\"feature-icon\">\n                <i class=\"fas fa-check\"></i>\n              </div>\n              <div>\n                <h4>Digital Marketing</h4>\n                <p>Strategic campaigns that drive results</p>\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"about-visual\">\n          <div class=\"visual-card\">\n            <img src=\"/images/about1.webp\" alt=\"Buy Dream Web Team\">\n          </div>\n          <div class=\"experience-badge\">\n            <div class=\"badge-icon\">\n              <i class=\"fas fa-award\"></i>\n            </div>\n            <div class=\"badge-text\">\n              <span class=\"badge-number\">15+</span>\n              <span class=\"badge-label\">Years of Excellence</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Core Values Section -->\n  <section class=\"core-values-section\">\n    <div class=\"core-container\">\n      <div class=\"section-header\">\n        <span class=\"section-tag\">Why Choose Us</span>\n        <h2>Our Core <span>Values</span></h2>\n        <p>The principles that guide everything we do and ensure your success.</p>\n      </div>\n      \n      <div class=\"values-grid\">\n        <div class=\"value-card\">\n          <div class=\"value-icon\">\n            <i class=\"fas fa-handshake\"></i>\n          </div>\n          <h3>Dedicated Support</h3>\n          <p>24/7 assistance to ensure your project succeeds at every stage.</p>\n        </div>\n        <div class=\"value-card\">\n          <div class=\"value-icon\">\n            <i class=\"fas fa-search\"></i>\n          </div>\n          <h3>SEO Optimization</h3>\n          <p>Data-driven strategies to boost your search rankings.</p>\n        </div>\n        <div class=\"value-card\">\n          <div class=\"value-icon\">\n            <i class=\"fas fa-tools\"></i>\n          </div>\n          <h3>Custom Solutions</h3>\n          <p>Tailored approaches that fit your unique needs.</p>\n        </div>\n        <div class=\"value-card\">\n          <div class=\"value-icon\">\n            <i class=\"fas fa-bullhorn\"></i>\n          </div>\n          <h3>Marketing Automation</h3>\n          <p>Streamlined campaigns for maximum impact.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Services Highlights -->\n  <section class=\"highlights-section\">\n    <div class=\"highlights-container\">\n      <div class=\"section-header\">\n        <span class=\"section-tag\">What We Do</span>\n        <h2>Our <span>Expertise</span></h2>\n      </div>\n      \n      <div class=\"highlight-grid\">\n        <div class=\"highlight-card\">\n          <div class=\"highlight-icon\">\n            <i class=\"fas fa-store\"></i>\n          </div>\n          <h3>E-Commerce Solutions</h3>\n          <p>Advanced e-commerce development with seamless functionality and user-centric designs that drive online sales.</p>\n        </div>\n        \n        <div class=\"highlight-card\">\n          <div class=\"highlight-icon\">\n            <i class=\"fas fa-chart-line\"></i>\n          </div>\n          <h3>SEO Services</h3>\n          <p>Data-driven SEO methodologies to boost visibility and drive organic traffic for sustainable growth.</p>\n        </div>\n        \n        <div class=\"highlight-card\">\n          <div class=\"highlight-icon\">\n            <i class=\"fas fa-rocket\"></i>\n          </div>\n          <h3>Digital Marketing</h3>\n          <p>Targeted campaigns that build brand loyalty and amplify your presence across platforms.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Meet Our Team -->\n  <section class=\"team-section\">\n    <div class=\"team-container\">\n      <div class=\"section-header\">\n        <span class=\"section-tag\">Our Team</span>\n        <h2>Meet Our <span>Experts</span></h2>\n        <p>The talented people behind our success.</p>\n      </div>\n      \n      <div class=\"team-grid\">\n        <div class=\"team-card\">\n          <div class=\"team-image\">\n            <img src=\"https://buydreamweb.com/wp-content/uploads/2025/10/ec2499a9-5f6e-4ab3-8fd0-0d93f7df9b66.webp\" alt=\"William James\">\n            <div class=\"team-overlay\">\n              <div class=\"social-links\">\n                <a href=\"#\"><i class=\"fab fa-linkedin-in\"></i></a>\n                <a href=\"#\"><i class=\"fab fa-twitter\"></i></a>\n              </div>\n            </div>\n          </div>\n          <h3>William James</h3>\n          <p class=\"team-role\">Co-Founder</p>\n        </div>\n        \n        <div class=\"team-card\">\n          <div class=\"team-image\">\n            <img src=\"https://buydreamweb.com/wp-content/uploads/2025/10/2-3-1.webp\" alt=\"Sarah Taylor\">\n            <div class=\"team-overlay\">\n              <div class=\"social-links\">\n                <a href=\"#\"><i class=\"fab fa-linkedin-in\"></i></a>\n                <a href=\"#\"><i class=\"fab fa-twitter\"></i></a>\n              </div>\n            </div>\n          </div>\n          <h3>Sarah Taylor</h3>\n          <p class=\"team-role\">Team Lead</p>\n        </div>\n        \n        <div class=\"team-card\">\n          <div class=\"team-image\">\n            <img src=\"https://buydreamweb.com/wp-content/uploads/2025/10/3-3-1.webp\" alt=\"Emma Ava\">\n            <div class=\"team-overlay\">\n              <div class=\"social-links\">\n                <a href=\"#\"><i class=\"fab fa-linkedin-in\"></i></a>\n                <a href=\"#\"><i class=\"fab fa-twitter\"></i></a>\n              </div>\n            </div>\n          </div>\n          <h3>Emma Ava</h3>\n          <p class=\"team-role\">Mobile Developer</p>\n        </div>\n        \n        <div class=\"team-card\">\n          <div class=\"team-image\">\n            <img src=\"https://buydreamweb.com/wp-content/uploads/2025/10/4-3-1.webp\" alt=\"John Trent\">\n            <div class=\"team-overlay\">\n              <div class=\"social-links\">\n                <a href=\"#\"><i class=\"fab fa-linkedin-in\"></i></a>\n                <a href=\"#\"><i class=\"fab fa-twitter\"></i></a>\n              </div>\n            </div>\n          </div>\n          <h3>John Trent</h3>\n          <p class=\"team-role\">Marketing Manager</p>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>\n\n<FooterSection />\n</template>\n\n<script setup>\nimport { onMounted } from 'vue'\nimport FooterSection from '@/components/FooterSection.vue'\nimport NavbarSection from '@/components/NavbarSection.vue'\n\nonMounted(() => {\n  const cards = document.querySelectorAll('.team-card')\n  const observer = new IntersectionObserver((entries) => {\n    entries.forEach((entry, index) => {\n      if (entry.isIntersecting) {\n        setTimeout(() => {\n          entry.target.style.opacity = '1'\n          entry.target.style.transform = 'translateY(0)'\n        }, index * 100)\n      }\n    })\n  }, { threshold: 0.1 })\n\n  cards.forEach(card => {\n    card.style.opacity = '0'\n    card.style.transform = 'translateY(30px)'\n    card.style.transition = 'all 0.6s ease'\n    observer.observe(card)\n  })\n})\n</script>\n\n<style scoped>\n.about-page {\n  min-height: 100vh;\n  background: #f8fafc;\n}\n\n.about-hero {\n  padding: 200px 6% 140px;\n  background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);